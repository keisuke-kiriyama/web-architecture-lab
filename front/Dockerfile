# =============================================================================
# Next.js 開発用 Dockerfile
# =============================================================================
#
# 【学習ポイント】
# 開発環境ではソースコードをマウントし、ホットリロードを有効にする。
# Next.js の開発サーバーはファイル変更を検知して自動再読み込みする。
#
# 【Reviewer観点】
# - 本番環境では next build → next start を使う
# - node_modules はコンテナ内で管理（ホストと混在させない）
# =============================================================================

FROM node:20-alpine

WORKDIR /app

# package.json と package-lock.json をコピー
COPY package*.json ./

# 依存関係をインストール
RUN npm install

# ソースコードをコピー（開発時は volume でマウントされるため上書きされる）
COPY . .

# 開発サーバー起動
# Next.js は 0.0.0.0 にバインドしないと Docker 外からアクセスできない
CMD ["npm", "run", "dev"]
